---
type Props = {
  title?: string;
  description?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
};

const {
  title = 'Ship your first workflow today',
  description =
    'Follow the getting-started guide, run an example, and evolve into production-grade orchestration patterns.',
  primaryHref = '/docs/getting-started',
  primaryLabel = 'Get started',
  secondaryHref = '/docs',
  secondaryLabel = 'Browse docs',
} = Astro.props;
---

<section class="mx-auto max-w-6xl px-4 py-16">
  <div class="rounded-2xl border border-white/10 bg-white/5 p-8 md:flex md:items-center md:justify-between">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold tracking-tight text-white">{title}</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-300">{description}</p>
    </div>
    <div class="mt-6 flex flex-col gap-3 sm:flex-row md:mt-0">
      <a
        href={primaryHref}
        class="inline-flex items-center justify-center rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-950 hover:bg-slate-100"
      >
        {primaryLabel}
      </a>
      <a
        href={secondaryHref}
        class="inline-flex items-center justify-center rounded-md border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-white hover:bg-white/10"
      >
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>
