---
import { site } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-slate-950">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-2 font-semibold">
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-white/10 ring-1 ring-white/15">
          <span class="text-sm">GX</span>
        </span>
        <span>{site.name}</span>
      </div>
      <p class="mt-3 text-sm text-slate-300">{site.description}</p>
    </div>

    <div class="text-sm">
      <div class="font-medium text-slate-200">Links</div>
      <ul class="mt-3 space-y-2 text-slate-300">
        <li><a class="hover:text-white" href="/docs">Docs</a></li>
        <li><a class="hover:text-white" href="/examples">Examples</a></li>
        <li>
          <a class="hover:text-white" href={site.links.github} target="_blank" rel="noreferrer">GitHub</a>
        </li>
      </ul>
    </div>

    <div class="text-sm">
      <div class="font-medium text-slate-200">Legal</div>
      <p class="mt-3 text-slate-300">MIT License — entire framework</p>
      <p class="mt-2 text-slate-400">© {year} {site.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
