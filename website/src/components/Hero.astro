---
import { site } from '../config/site';

type Props = {
  title?: string;
  subtitle?: string;
};

const {
  title = `${site.name} — ${site.tagline}`,
  subtitle =
    'Build, run, and evolve multi-agent workflows with graph orchestration, multi-layer memory, and an extensible tool system. Fully open source — production features included.',
} = Astro.props;
---

<section class="relative overflow-hidden border-b border-white/10">
  <div class="absolute inset-0 bg-grid opacity-40"></div>
  <div
    class="pointer-events-none absolute left-1/2 top-[-200px] h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-white/10 blur-3xl"
  ></div>

  <div class="relative mx-auto max-w-6xl px-4 py-16 md:py-24">
    <div class="grid items-center gap-10 md:grid-cols-2 md:gap-12">
      <div class="max-w-3xl">
        <p class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs text-slate-200">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
          100% open source · MIT licensed
        </p>

        <h1 class="mt-6 text-balance text-4xl font-semibold tracking-tight text-white md:text-6xl">
          {title}
        </h1>
        <p class="mt-5 text-pretty text-lg leading-relaxed text-slate-200 md:text-xl">
          {subtitle}
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/docs/getting-started"
            class="inline-flex items-center justify-center rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-950 hover:bg-slate-100"
          >
            Get started
          </a>
          <a
            href="/product"
            class="inline-flex items-center justify-center rounded-md border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-white hover:bg-white/10"
          >
            Explore the platform
          </a>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          <div class="rounded-xl border border-white/10 bg-white/5 p-4">
            <div class="text-sm font-semibold">Graph-first</div>
            <div class="mt-1 text-sm text-slate-300">Complex orchestration with routing, loops, and parallelism.</div>
          </div>
          <div class="rounded-xl border border-white/10 bg-white/5 p-4">
            <div class="text-sm font-semibold">Memory layers</div>
            <div class="mt-1 text-sm text-slate-300">Short/long-term, episodic, semantic, procedural, working.</div>
          </div>
          <div class="rounded-xl border border-white/10 bg-white/5 p-4">
            <div class="text-sm font-semibold">Tool ecosystem</div>
            <div class="mt-1 text-sm text-slate-300">Built-ins, custom tools, MCP servers, and registries.</div>
          </div>
        </div>
      </div>

      <div class="relative">
        <!-- Photo source: Unsplash https://unsplash.com/photos/a-couple-of-little-robots-standing-next-to-each-other-aaujbh59zqI -->
        <div class="relative overflow-hidden rounded-2xl border border-white/10 bg-white/5 shadow-2xl shadow-black/30">
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-slate-950/40 via-slate-950/10 to-transparent"></div>
          <div class="aspect-[4/3]">
            <img
              src="/hero.jpg"
              alt="Two robots collaborating"
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
