---
import { site } from '../config/site';

const nav = [
  { label: 'Product', href: '/product' },
  { label: 'Install', href: '/install' },
  { label: 'Docs', href: '/docs' },
  { label: 'Examples', href: '/examples' },
  { label: 'Enterprise', href: '/enterprise' },
] as const;
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-slate-950/70 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-white/10 ring-1 ring-white/15">
        <span class="text-sm">GX</span>
      </span>
      <span>{site.name}</span>
    </a>

    <nav class="hidden items-center gap-6 text-sm text-slate-200 md:flex">
      {nav.map((item) => (
        <a href={item.href} class="hover:text-white">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/docs/getting-started"
        class="hidden rounded-md bg-white px-3 py-2 text-sm font-medium text-slate-950 hover:bg-slate-100 md:inline-flex"
      >
        Get started
      </a>
      <a
        href={site.links.github}
        target="_blank"
        rel="noreferrer"
        class="inline-flex rounded-md border border-white/15 bg-white/5 px-3 py-2 text-sm font-medium text-slate-100 hover:bg-white/10"
      >
        GitHub
      </a>
    </div>
  </div>
</header>
