---
type Props = {
  title: string;
  eyebrow?: string;
  description?: string;
};

const { title, eyebrow, description } = Astro.props;
---

<section class="mx-auto max-w-6xl px-4 py-14 md:py-20">
  <div class="max-w-2xl">
    {eyebrow ? <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">{eyebrow}</p> : null}
    <h2 class="mt-3 text-2xl font-semibold tracking-tight text-white md:text-3xl">{title}</h2>
    {description ? <p class="mt-4 text-base leading-relaxed text-slate-300">{description}</p> : null}
  </div>
  <div class="mt-10">
    <slot />
  </div>
</section>
