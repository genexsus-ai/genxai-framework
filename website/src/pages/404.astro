---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="Page not found" noIndex>
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="rounded-2xl border border-white/10 bg-white/5 p-10">
      <h1 class="text-3xl font-semibold tracking-tight text-white">Page not found</h1>
      <p class="mt-3 text-sm text-slate-300">
        The page you’re looking for doesn’t exist.
      </p>
      <div class="mt-8 flex gap-3">
        <a
          class="inline-flex items-center justify-center rounded-md bg-white px-5 py-3 text-sm font-semibold text-slate-950 hover:bg-slate-100"
          href="/"
        >
          Go home
        </a>
        <a
          class="inline-flex items-center justify-center rounded-md border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-white hover:bg-white/10"
          href="/docs"
        >
          Browse docs
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
