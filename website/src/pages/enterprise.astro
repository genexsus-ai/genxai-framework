---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const oss = [
  'Graph engine, flows, agents, memory, tools, providers',
  'Examples and documentation',
  'MIT-licensed core framework',
];

const ent = [
  'No-code Studio (visual workflow builder)',
  'Enterprise connectors, triggers, and SDKs',
  'Observability, security, governance, and scaling features',
];
---

<BaseLayout title="Enterprise" description="Understand the open-source core vs enterprise capabilities in the GenXAI ecosystem.">
  <Section
    eyebrow="Packaging"
    title="Open-source core, enterprise capabilities"
    description="This repository focuses on the MIT-licensed GenXAI core. Enterprise features are staged under /enterprise and intended for a separate commercial distribution."
  >
    <div class="grid gap-4 md:grid-cols-2">
      <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
        <h3 class="text-base font-semibold text-white">Open-source (MIT)</h3>
        <p class="mt-2 text-sm text-slate-300">Use these pieces for OSS releases and community adoption.</p>
        <ul class="mt-4 space-y-2 text-sm text-slate-300">
          {oss.map((i) => (
            <li class="flex gap-2">
              <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-emerald-400/80"></span>
              <span>{i}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
        <h3 class="text-base font-semibold text-white">Enterprise</h3>
        <p class="mt-2 text-sm text-slate-300">
          For production governance, integrations, and visual tooling.
        </p>
        <ul class="mt-4 space-y-2 text-sm text-slate-300">
          {ent.map((i) => (
            <li class="flex gap-2">
              <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-white/30"></span>
              <span>{i}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="rounded-2xl border border-white/10 bg-white/5 p-8">
      <h2 class="text-xl font-semibold text-white">How to talk about it</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-300">
        When presenting GenXAI publicly, position the core as the foundation (graph orchestration + memory + tools). Then describe enterprise
        features as the path to production operations: observability, governance, connectors, and the Studio.
      </p>
    </div>
  </section>
</BaseLayout>
