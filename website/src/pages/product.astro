---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import FeatureGrid from '../components/FeatureGrid.astro';

const features = [
  {
    title: 'Graph Engine',
    description:
      'Execute workflows as directed graphs with dynamic routing, conditions, parallelism, cycles, and composition.',
    bullets: ['Compile/validate graphs', 'Versioning-ready architecture', 'Visualize execution paths'],
  },
  {
    title: 'Flows (coordination patterns)',
    description:
      '14 drop-in orchestrators for common multi-agent patterns so teams can standardize on proven designs.',
    bullets: [
      'Parallel · Router · Conditional · Loop',
      'Critic review · Ensemble voting · Map-reduce',
      'Coordinator-worker · Delegator · Subworkflow',
      'Round-robin · Selector · P2P · Auction',
    ],
  },
  {
    title: 'Agents',
    description:
      'Configurable roles, goals, models, tools, and memory settings. Keep behavior explicit and testable.',
    bullets: ['Factory + registry', 'Guardrails and constraints', 'Multi-provider LLM routing'],
  },
  {
    title: 'Memory System',
    description:
      'Layered memory architecture (short/long-term, episodic, semantic, procedural, working) to retain and retrieve context.',
    bullets: ['Consolidation and retrieval', 'Redis, SQLite, Neo4j backend plugins', 'Importance-based retention'],
  },
  {
    title: 'Tooling + MCP',
    description:
      'A tool registry with templates and secure execution. Connect external systems safely via MCP.',
    bullets: ['30+ built-in tools + custom tools', 'Dynamic tool creation', 'MCP client and server', 'Approval + audit hooks'],
  },
  {
    title: 'LLM Providers',
    description:
      'First-class support for the major model providers, with routing to mix models across agents in one workflow.',
    bullets: ['OpenAI · Anthropic · Google · Cohere · Ollama', 'Multi-provider LLM routing', 'Opt-in LLM ranking for tool selection'],
  },
  {
    title: 'Connectors',
    description:
      'Ready-made integrations so agents can read from and act on the systems your business already runs on.',
    bullets: [
      'Slack · GitHub · Jira · Notion',
      'Google Workspace · HubSpot · WhatsApp',
      'Kafka · SQS · Postgres CDC · S3 · SMTP · Webhooks',
    ],
  },
  {
    title: 'Triggers',
    description:
      'Start workflows automatically from external events instead of manual runs.',
    bullets: ['Webhook triggers', 'Schedules (cron)', 'Queue + file-watcher triggers'],
  },
  {
    title: 'No-Code Workflow Studio',
    description:
      'An n8n-style drag-and-drop visual builder: compose agent/tool pipelines on a canvas and run them with live per-node status.',
    bullets: ['Drag agents, tools, decisions, loops', 'Live execution status', 'Included in the repository'],
  },
  {
    title: 'Production runtime',
    description:
      'Observability, security, and deployment tooling ship with the framework — all MIT-licensed.',
    bullets: ['Logging, metrics, tracing', 'RBAC, policy engine, audit, rate limits', 'CLI + REST API + Docker/K8s manifests'],
  },
] as const;
---

<BaseLayout title="Product" description="Explore GenXAI’s platform: graph engine, flows, memory, tools, LLM providers, connectors, triggers, and production runtime.">
  <Section
    eyebrow="Platform"
    title="Everything you need to orchestrate agent systems"
    description="GenXAI is designed for real-world workflows: explicit state, repeatable execution, and extensibility from day one."
  >
    <FeatureGrid features={features} />
  </Section>

  <section class="mx-auto max-w-6xl px-4 pb-16">
    <div class="rounded-2xl border border-white/10 bg-white/5 p-8">
      <h2 class="text-xl font-semibold text-white">Recommended starting path</h2>
      <ol class="mt-4 space-y-3 text-sm text-slate-300">
        <li><span class="font-semibold text-white">1.</span> Follow <a class="underline" href="/docs/getting-started">Getting Started</a>.</li>
        <li><span class="font-semibold text-white">2.</span> Run an example from <a class="underline" href="/examples">Examples</a>.</li>
        <li><span class="font-semibold text-white">3.</span> Learn patterns in <a class="underline" href="/docs/concepts/flows">Flows</a>.</li>
      </ol>
    </div>
  </section>
</BaseLayout>
